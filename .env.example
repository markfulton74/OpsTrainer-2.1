# ============================================
# OpsTrainer 2.1 — Environment Variables
# Copy this to .env and fill in your values
# ============================================

# Server
PORT=3000
NODE_ENV=development

# Security — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-jwt-secret-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Database
DB_PATH=./data/opstrainer.db

# AI — DeepSeek
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
STRIPE_STARTER_PRICE_ID=price_xxx
STRIPE_TEAM_PRICE_ID=price_xxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxx

# Email (Resend or SMTP)
RESEND_API_KEY=your-resend-key
EMAIL_FROM=noreply@opstrainer.co.za

# App URL
APP_URL=http://localhost:3000
